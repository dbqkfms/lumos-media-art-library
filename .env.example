# LUMOS Platform Demo — 환경 변수 예시
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# .env 파일은 절대 커밋하지 마세요.

# --- 서버 ---
PORT=3000
NODE_ENV=development

# --- 이메일 (선택) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Vimeo API (선택) ---
VIMEO_TOKEN=
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=

# --- Gemini / Vertex AI (선택) ---
# ADC(Application Default Credentials) 우선. 없으면 아래 키 사용.
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
# 또는 API key (테스트용)
GEMINI_API_KEY=

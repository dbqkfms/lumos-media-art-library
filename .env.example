# LUMOS Platform Demo — 환경 변수 예시
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# .env 파일은 절대 커밋하지 마세요.

# --- 서버 ---
PORT=3000
NODE_ENV=development

# --- Stitch AI (Google Labs) ---
# stitch.withgoogle.com > Profile > Stitch Settings > API Keys
STITCH_API_KEY=

# --- Gemini / Vertex AI ---
# 코딩/프론트: gemini-3.1-pro-preview
# 이미지 생성: gemini-3.1-flash-image-preview (Nano Banana 2)
# ADC 우선, 없으면 API key 사용
GEMINI_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=

# --- Vimeo API ---
# developer.vimeo.com/apps 에서 발급
VIMEO_TOKEN=

# --- 이메일 (선택) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
